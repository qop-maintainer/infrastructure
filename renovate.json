{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:nonOfficeHours",
    ":gitSignOff"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "mise"
      ],
      "groupName": "terraform-lockstep",
      "matchPackageNames": [
        "/^terraform/"
      ]
    },
    {
      "matchManagers": [
        "terraform"
      ],
      "groupName": "terraform-lockstep",
      "matchPackageNames": [
        "/^terraform/"
      ]
    }
  ],
  "internalChecksFilter": "strict",
  "minimumReleaseAge": "3 days",
  "pre-commit": {
    "enabled": true
  },
  "timezone": "Europe/London",
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ]
  }
}
